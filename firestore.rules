rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Safety first
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Super Admin: Identification by hardcoded email
    function isSuperAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "denacchy@gmail.com" || 
         request.auth.token.email == "DENACCHY@GMAIL.COM");
    }

    // Standard Admin: Checks admins collection
    function isCollectionAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() { 
      return isSuperAdmin() || isCollectionAdmin();
    }

    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balances', 'createdAt'])
        && data.uid == request.auth.uid
        && (data.email == request.auth.token.email || !data.keys().hasAny(['email']))
        && data.balances.main is number && data.balances.main >= 0
        && data.createdAt == request.time;
    }

    // --- Rules ---

    // Users: Owners can read/write their own profiles. Admins can read all.
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && (resource.data.referredBy == request.auth.uid));
      allow create: if isOwner(userId) && isValidUser(incoming()) && (incoming().get('isAdmin', false) == false || isSuperAdmin());
      allow update: if isOwner(userId) 
        && incoming().uid == existing().uid
        && (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'isAdmin', 'balances', 'referredBy', 'referralCode', 'profileUpdated']))
        && (incoming().get('isAdmin', false) == existing().get('isAdmin', false) || isAdmin());
        
      // Special allowance for Super Admin to update anything in users
      allow update: if isSuperAdmin();
    }

    // Courses: Any signed-in user can read. Only admins can write.
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Enrolments: Owners and Admins.
    match /enrolments/{enrolmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Tasks: Any signed-in user can read. Only admins can write.
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Task Completions
    match /taskCompletions/{completionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    // Transactions: Core financial logs.
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Withdrawals
    match /withdrawals/{withdrawalId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() || isOwner(adminId); 
      allow update, delete: if isSuperAdmin();
    }

    // System Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
